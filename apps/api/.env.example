# Configuracion de entorno para la API de Kanban Retail
# Copiar a .env y ajustar valores.

# Base de datos. Para PostgreSQL usar:
#   postgresql://usuario:password@localhost:5432/kanban_retail
# Para desarrollo/tests local se acepta SQLite:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kanban_retail

# Clave secreta para firmar las cookies de sesion. Cambiar en produccion.
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria

# Origenes permitidos para CORS separados por coma.
CORS_ORIGINS=http://localhost:3000

# Entorno: development | production | test
ENVIRONMENT=development

# Enviar cookie solo por HTTPS (true en produccion).
COOKIE_SECURE=false

# Duracion de la sesion en segundos (por defecto 8 horas).
SESSION_MAX_AGE=28800

# Nombre de la cookie de sesion.
SESSION_COOKIE_NAME=kanban_session

# Limite de peticiones por ventana (rate limiting simple en memoria).
RATE_LIMIT_MAX_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60
